# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
WEBHOOK_SECRET=your_webhook_secret_here

# AI Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Supabase (required for API — see backend/src/config/env.ts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Shadow Execution Agent (non-blocking security queue → shadow_findings table)
# Google consumer API may not expose gemini-1.5-*; override if your project still has access.
GEMINI_SHADOW_MODEL=gemini-2.5-flash
SHADOW_EXECUTION_ENABLED=true
SHADOW_MAX_FILES=12
SHADOW_MAX_APPROX_TOKENS=24000
SHADOW_SKIP_TEST_PATHS=false

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=code_review_metrics
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Server Configuration
PORT=3000
